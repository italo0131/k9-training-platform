# Producao - obrigatorio para subir a aplicacao
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/k9_training?schema=public"
NEXTAUTH_URL="https://app.k9training.com.br"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY="replace-with-base64-32-byte-key"
AUTH_TRUST_HOST="true"
ALLOWED_ORIGINS="https://app.k9training.com.br,https://www.k9training.com.br"
ADMIN_API_KEY="replace-admin-api-key"
ROOT_ADMIN_KEY="replace-root-admin-key"

# Pagamento - obrigatorio se o checkout real estiver ativo
PAYMENT_PROVIDER="ASAAS"
BILLING_PROVIDER="ASAAS"
ASAAS_SANDBOX="false"
ASAAS_API_BASE_URL="https://api.asaas.com/v3"
ASAAS_API_KEY="replace-with-asaas-api-key"
ASAAS_WEBHOOK_TOKEN="replace-with-asaas-webhook-token"

# Email - configure pelo menos um provedor
# Opcao A: SMTP
SMTP_HOST="smtp.seu-provedor.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="smtp-user"
SMTP_PASS="smtp-password"
EMAIL_FROM_NAME="K9 Training"
EMAIL_FROM_ADDRESS="no-reply@k9training.com.br"
EMAIL_REPLY_TO="suporte@k9training.com.br"

# Opcao B: Resend (use se nao for usar SMTP)
RESEND_API_KEY=""

# Opcional - IA e APIs externas
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_BREED_MODEL="gpt-4o-mini"
THEDOGAPI_API_KEY=""
DOG_API_KEY=""

# Opcional - legado Stripe
STRIPE_SECRET_KEY=""
STRIPE_PRICE_ID=""
STRIPE_PRICE_ID_STANDARD=""
STRIPE_PRICE_ID_STARTER=""
STRIPE_SUCCESS_URL="https://app.k9training.com.br/billing/sucesso"
STRIPE_CANCEL_URL="https://app.k9training.com.br/billing"
STRIPE_WEBHOOK_SECRET=""

# Opcional - infra complementar
REDIS_URL=""
