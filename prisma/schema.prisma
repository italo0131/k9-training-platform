generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String    @id @default(cuid())
  name                String
  email               String    @unique
  password            String
  role                String    @default("CLIENT")
  status              String    @default("ACTIVE")
  plan                String    @default("FREE")
  planStatus          String    @default("ACTIVE")
  planActivatedAt     DateTime?
  asaasCustomerId     String?   @unique
  asaasWalletId       String?
  headline            String?
  bio                 String?
  city                String?
  state               String?
  specialties         String?
  experienceYears     Int?
  availabilityNotes   String?
  websiteUrl          String?
  instagramHandle     String?
  companyId           String?
  company             Company?  @relation(fields: [companyId], references: [id])
  emailVerifiedAt     DateTime?
  phone               String?
  phoneVerifiedAt     DateTime?
  twoFactorEnabled    Boolean   @default(false)
  breedAdvisorProfile Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  dogs                 Dog[]
  schedules            Schedule[]
  assignedSchedules    Schedule[]            @relation("ScheduleTrainer")
  blogPosts            BlogPost[]
  blogComments         BlogComment[]         @relation("UserBlogComments")
  blogReactions        BlogPostReaction[]
  forumChannels        ForumChannel[]        @relation("ForumChannelOwner")
  channelSubscriptions ChannelSubscription[]
  channelContents      ChannelContent[]      @relation("ChannelContentAuthor")
  forumThreads         ForumThread[]         @relation("UserForumThreads")
  forumThreadReactions ForumThreadReaction[]
  forumReplies         ForumReply[]          @relation("UserForumReplies")
  coachedTrainings     TrainingSession[]     @relation("TrainingSessionCoach")
  payments             Payment[]
  subscriptions        Subscription[]        @relation("UserSubscriptions")
  transactions         Transaction[]         @relation("UserTransactions")
  auditLogs            AuditLog[]
  verificationCodes    VerificationCode[]
  forumPosts           ForumPost[]           @relation("UserForumPosts")
}

model Company {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  users     User[]
  dogs      Dog[]
}

model Dog {
  id                         String            @id @default(cuid())
  name                       String
  breed                      String
  breedApiId                 String?
  breedGroup                 String?
  breedOrigin                String?
  breedTemperament           String?
  breedDescription           String?
  breedLifeSpan              String?
  breedWeightMinKg           Float?
  breedWeightMaxKg           Float?
  breedHeightReferenceCm     String?
  breedReferenceImageUrl     String?
  age                        Int
  size                       String?
  weightKg                   Float?
  gender                     String?
  color                      String?
  birthDate                  DateTime?
  foodName                   String?
  mealsPerDay                Int?
  portionSize                String?
  feedingTimes               String?
  allergies                  String?
  medications                String?
  healthNotes                String?
  behaviorNotes              String?
  energyLevel                String?
  activityProfile            String            @default("COMPANION")
  sportFocus                 String?
  dailyExerciseGoalMinutes   Int?
  weeklyConditioningSessions Int?
  bodyConditionScore         Int?
  restingHeartRateBpm        Int?
  athleteClearance           Boolean           @default(false)
  lastVetCheckupAt           DateTime?
  hydrationPlan              String?
  supplements                String?
  injuryHistory              String?
  veterinaryRestrictions     String?
  recoveryNotes              String?
  performanceGoals           String?
  vaccinated                 Boolean           @default(false)
  neutered                   Boolean           @default(false)
  ownerId                    String
  owner                      User              @relation(fields: [ownerId], references: [id])
  companyId                  String?
  company                    Company?          @relation(fields: [companyId], references: [id])
  schedules                  Schedule[]
  trainings                  TrainingSession[]
  createdAt                  DateTime          @default(now())
}

model TrainingSession {
  id              String   @id @default(cuid())
  title           String
  description     String?
  focusArea       String?
  difficulty      String?
  durationMinutes Int?
  trainerNotes    String?
  homework        String?
  videoUrl        String?
  progress        Int
  dogId           String
  dog             Dog      @relation(fields: [dogId], references: [id])
  coachId         String?
  coach           User?    @relation("TrainingSessionCoach", fields: [coachId], references: [id])
  executedAt      DateTime @default(now())
  createdAt       DateTime @default(now())
}

model Schedule {
  id              String        @id @default(cuid())
  title           String        @default("Sessao de treino")
  notes           String?
  location        String?
  format          String        @default("PRESENTIAL")
  durationMinutes Int?
  date            DateTime
  status          String
  price           Int?
  paymentStatus   String        @default("PENDING")
  asaasPaymentId  String?       @unique
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  trainerId       String?
  trainer         User?         @relation("ScheduleTrainer", fields: [trainerId], references: [id])
  dogId           String?
  dog             Dog?          @relation(fields: [dogId], references: [id])
  transactions    Transaction[] @relation("ScheduleTransactions")
}

model BlogPost {
  id            String             @id @default(cuid())
  title         String
  slug          String             @unique
  category      String             @default("GERAL")
  postType      String             @default("POST")
  accessLevel   String             @default("FREE")
  excerpt       String?
  content       String
  coverImageUrl String?
  videoUrl      String?
  featured      Boolean            @default(false)
  eventStartsAt DateTime?
  eventEndsAt   DateTime?
  eventLocation String?
  eventCity     String?
  eventState    String?
  published     Boolean            @default(true)
  authorId      String
  author        User               @relation(fields: [authorId], references: [id])
  comments      BlogComment[]
  reactions     BlogPostReaction[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model Payment {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  type          String
  status        String?
  amount        Int?
  currency      String?
  customerEmail String?
  customerId    String?
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])
  raw           String?
  createdAt     DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id])
  action     String
  targetType String
  targetId   String?
  metadata   String?
  createdAt  DateTime @default(now())
}

model ForumChannel {
  id                   String                @id @default(cuid())
  slug                 String                @unique
  name                 String
  description          String
  category             String                @default("COMUNIDADE")
  serviceMode          String                @default("COMMUNITY")
  subscriptionPrice    Int?
  onlinePrice          Int?
  inPersonPrice        Int?
  city                 String?
  state                String?
  acceptsRemote        Boolean               @default(false)
  isPublic             Boolean               @default(true)
  featured             Boolean               @default(false)
  ownerId              String
  owner                User                  @relation("ForumChannelOwner", fields: [ownerId], references: [id])
  subscriptions        ChannelSubscription[]
  billingSubscriptions Subscription[]        @relation("ForumChannelSubscriptions")
  contents             ChannelContent[]
  threads              ForumThread[]
  transactions         Transaction[]         @relation("ForumChannelTransactions")
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
}

model ChannelSubscription {
  id                  String        @id @default(cuid())
  status              String        @default("ACTIVE")
  tier                String        @default("FREE")
  paymentStatus       String        @default("PENDING")
  asaasCheckoutId     String?       @unique
  asaasSubscriptionId String?       @unique
  asaasPaymentId      String?
  startedAt           DateTime      @default(now())
  endedAt             DateTime?
  channelId           String
  channel             ForumChannel  @relation(fields: [channelId], references: [id])
  userId              String
  user                User          @relation(fields: [userId], references: [id])
  billingSubscription Subscription? @relation("ChannelSubscriptionBilling")

  @@unique([channelId, userId])
}

model Subscription {
  id                    String               @id @default(cuid())
  provider              String               @default("ASAAS")
  externalReference     String               @unique
  planType              String
  planCode              String?
  billingCycle          String?
  status                String               @default("PENDING")
  checkoutStatus        String?
  paymentStatus         String?
  amount                Int
  commissionAmount      Int                  @default(0)
  netAmount             Int?
  asaasCustomerId       String?
  asaasCheckoutId       String?              @unique
  asaasSubscriptionId   String?              @unique
  asaasPaymentId        String?
  startAt               DateTime?
  endAt                 DateTime?
  metadata              Json?
  userId                String
  user                  User                 @relation("UserSubscriptions", fields: [userId], references: [id])
  channelId             String?
  channel               ForumChannel?        @relation("ForumChannelSubscriptions", fields: [channelId], references: [id])
  channelSubscriptionId String?              @unique
  channelSubscription   ChannelSubscription? @relation("ChannelSubscriptionBilling", fields: [channelSubscriptionId], references: [id])
  transactions          Transaction[]
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([userId, planType, status])
  @@index([channelId, status])
}

model Transaction {
  id                     String        @id @default(cuid())
  provider               String        @default("ASAAS")
  providerEventId        String?       @unique
  externalPaymentId      String?       @unique
  externalSubscriptionId String?
  type                   String
  status                 String
  grossAmount            Int?
  feeAmount              Int?
  netAmount              Int?
  currency               String?
  description            String?
  raw                    Json?
  userId                 String?
  user                   User?         @relation("UserTransactions", fields: [userId], references: [id])
  channelId              String?
  channel                ForumChannel? @relation("ForumChannelTransactions", fields: [channelId], references: [id])
  scheduleId             String?
  schedule               Schedule?     @relation("ScheduleTransactions", fields: [scheduleId], references: [id])
  subscriptionId         String?
  subscription           Subscription? @relation(fields: [subscriptionId], references: [id])
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  @@index([externalSubscriptionId])
  @@index([subscriptionId, type])
}

model ChannelContent {
  id              String       @id @default(cuid())
  slug            String       @unique
  title           String
  summary         String?
  body            String
  coverImageUrl   String?
  category        String       @default("TREINO")
  contentType     String       @default("LESSON")
  accessLevel     String       @default("SUBSCRIBER")
  objective       String?
  difficulty      String?
  durationMinutes Int?
  orderIndex      Int?
  videoUrl        String?
  published       Boolean      @default(true)
  authorId        String
  author          User         @relation("ChannelContentAuthor", fields: [authorId], references: [id])
  channelId       String
  channel         ForumChannel @relation(fields: [channelId], references: [id])
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model ForumPost {
  id        String      @id @default(cuid())
  content   String
  threadId  String
  thread    ForumThread @relation(fields: [threadId], references: [id])
  authorId  String
  author    User        @relation("UserForumPosts", fields: [authorId], references: [id])
  createdAt DateTime    @default(now())
}

model ForumThread {
  id            String                @id @default(cuid())
  title         String
  content       String
  postType      String                @default("POST")
  imageUrl      String?
  videoUrl      String?
  eventStartsAt DateTime?
  eventEndsAt   DateTime?
  eventLocation String?
  eventCity     String?
  eventState    String?
  channelId     String?
  channel       ForumChannel?         @relation(fields: [channelId], references: [id])
  isPinned      Boolean               @default(false)
  authorId      String
  author        User                  @relation("UserForumThreads", fields: [authorId], references: [id])
  replies       ForumReply[]
  reactions     ForumThreadReaction[]
  posts         ForumPost[] // <-- ADICIONE ESTA LINHA
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
}

model ForumReply {
  id        String      @id @default(cuid())
  content   String
  authorId  String
  author    User        @relation("UserForumReplies", fields: [authorId], references: [id])
  threadId  String
  thread    ForumThread @relation(fields: [threadId], references: [id])
  createdAt DateTime    @default(now())
}

model VerificationCode {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model BlogComment {
  id        String   @id @default(cuid())
  content   String
  authorId  String
  author    User     @relation("UserBlogComments", fields: [authorId], references: [id])
  postId    String
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model BlogPostReaction {
  id        String   @id @default(cuid())
  type      String   @default("LIKE")
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model ForumThreadReaction {
  id        String      @id @default(cuid())
  type      String      @default("LIKE")
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  threadId  String
  thread    ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([threadId, userId])
}
