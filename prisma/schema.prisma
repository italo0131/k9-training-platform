generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
enum Role {
  ROOT
  SUPERADMIN
  ADMIN
  TRAINER
  CLIENT
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

model User {
  id                 String    @id @default(cuid())
  name               String
  email              String    @unique
  password           String
  role               Role      @default(CLIENT)
  status             UserStatus @default(ACTIVE)
  companyId          String?
  company            Company?  @relation(fields: [companyId], references: [id])
  emailVerifiedAt    DateTime?
  phone              String?
  phoneVerifiedAt    DateTime?
  twoFactorEnabled   Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  dogs               Dog[]
  schedules          Schedule[]
  blogPosts          BlogPost[]
  forumThreads       ForumThread[] @relation("UserForumThreads")
  forumReplies       ForumReply[]  @relation("UserForumReplies")
  payments           Payment[]
  auditLogs          AuditLog[]
  verificationCodes  VerificationCode[]
}

model Company {
  id          String   @id @default(cuid())
  name        String
  createdAt   DateTime @default(now())
  users       User[]
  dogs        Dog[]
}

model Dog {
  id        String   @id @default(cuid())
  name      String
  breed     String
  age       Int
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  trainings TrainingSession[]
  createdAt DateTime @default(now())
}

model TrainingSession {
  id          String   @id @default(cuid())
  title       String
  description String?
  progress    Int
  dogId       String
  dog         Dog      @relation(fields: [dogId], references: [id])
  createdAt   DateTime @default(now())
}

model Schedule {
  id       String   @id @default(cuid())
  date     DateTime
  status   String
  userId   String
  user     User     @relation(fields: [userId], references: [id])
}

model BlogPost {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  excerpt   String?
  content   String
  published Boolean  @default(true)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payment {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  type          String
  status        String?
  amount        Int?
  currency      String?
  customerEmail String?
  customerId    String?
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])
  raw           String?
  createdAt     DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id])
  action    String
  targetType String
  targetId  String?
  metadata  String?
  createdAt DateTime @default(now())
}

model ForumThread {
  id        String   @id @default(cuid())
  title     String
  content   String
  authorId  String
  author    User     @relation("UserForumThreads", fields: [authorId], references: [id])
  replies   ForumReply[]
  createdAt DateTime @default(now())
}

model ForumReply {
  id        String   @id @default(cuid())
  content   String
  authorId  String
  author    User     @relation("UserForumReplies", fields: [authorId], references: [id])
  threadId  String
  thread    ForumThread @relation(fields: [threadId], references: [id])
  createdAt DateTime @default(now())
}

model VerificationCode {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}
