# App / auth
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/k9_training?schema=public"
DATABASE_URL_DEV=""
DATABASE_HOST_FALLBACK="localhost"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"
ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
ADMIN_API_KEY="replace-admin-api-key"
ROOT_ADMIN_KEY="replace-root-admin-key"
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY="replace-with-base64-32-byte-key"

# Billing / payment provider
PAYMENT_PROVIDER="ASAAS"
BILLING_PROVIDER="ASAAS"

# Asaas
ASAAS_SANDBOX="true"
ASAAS_API_BASE_URL="https://api-sandbox.asaas.com/v3"
ASAAS_API_KEY="replace-with-asaas-api-key"
ASAAS_WEBHOOK_TOKEN="replace-with-asaas-webhook-token"

# Stripe legado / fallback
STRIPE_SECRET_KEY=""
STRIPE_PRICE_ID=""
STRIPE_PRICE_ID_STANDARD=""
STRIPE_PRICE_ID_STARTER=""
STRIPE_SUCCESS_URL="http://localhost:3000/billing/sucesso"
STRIPE_CANCEL_URL="http://localhost:3000/billing"
STRIPE_WEBHOOK_SECRET=""

# Email via SMTP
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="smtp-user"
SMTP_PASS="smtp-password"
EMAIL_FROM_NAME="K9 Training"
EMAIL_FROM_ADDRESS="no-reply@k9-training.com.br"
EMAIL_REPLY_TO="suporte@k9-training.com.br"

# Resend (opcional, fallback se SMTP nao estiver configurado)
RESEND_API_KEY="re_replace_me"

# APIs externas
THEDOGAPI_API_KEY="dog-api-key"
DOG_API_KEY=""
OPENAI_API_KEY="openai-api-key"
OPENAI_MODEL="gpt-4o-mini"
OPENAI_BREED_MODEL="gpt-4o-mini"

# Infra opcional
REDIS_URL="redis://localhost:6379"
